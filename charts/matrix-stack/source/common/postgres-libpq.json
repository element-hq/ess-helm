{
  "type": "object",
  "required": [
    "host",
    "user",
    "database"
  ],
  "properties": {
    "host": {
      "anyOf": [{"type": "string"}, {"$ref": "file://common/credential.json"}]
    },
    "port": {
      "anyOf": [
        {"type": "integer", "minimum": 0, "maximum": 65535},
        {"$ref": "file://common/credential.json"}
      ]
    },
    "user": {
      "anyOf": [{"type": "string"}, {"$ref": "file://common/credential.json"}]
    },
    "database": {
      "anyOf": [{"type": "string"}, {"$ref": "file://common/credential.json"}]
    },
    "sslMode": {
      "type": "string",
      "enum": [
        "disable",
        "allow",
        "prefer",
        "require",
        "verify-ca",
        "verify-full"
      ]
    },
    "password": {
      "$ref": "file://common/credential.json"
    }
  }
}
